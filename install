#!/usr/bin/env bash

# Require non-root sudo user
if [[ $EUID -eq 0 ]]; then
    echo "Please run this command as your normal user, not root (or sudo.)"
    exit 1
fi

DOTFILES=$(cd $(dirname "${BASH_SOURCE[0]}") && pwd)

# Ensure config dir exists
mkdir -p $HOME/.config -p

# Bash
ln -sf $DOTFILES/bash/bashrc $HOME/.bashrc
ln -sf $DOTFILES/bash/alias $HOME/.alias
ln -sf $DOTFILES/bash/prompt $HOME/.prompt
ln -sf $DOTFILES/bash/inputrc $HOME/.inputrc

# Git
ln -sf $DOTFILES/git/gitconfig $HOME/.gitconfig

# Kitty
rm -rf $HOME/.config/kitty
ln -s $DOTFILES/kitty $HOME/.config/kitty

# Tmux
ln -sf $DOTFILES/tmux/tmux.conf $HOME/.tmux.conf

# SSH agent
mkdir -p $HOME/.config/systemd/user
ln -sf $DOTFILES/systemd/ssh-agent.service $HOME/.config/systemd/user/ssh-agent.service
systemctl --user daemon-reload
systemctl --user enable --quiet --now ssh-agent.service

# Custom functions
rm -rf $HOME/.local/bin
ln -s $DOTFILES/bin $HOME/.local/bin

# Symfony
if ! command -v symfony &> /dev/null; then
    rm -rf "$HOME/.symfony5"
    rm -rf "$HOME/.config/symfony-cli"
    bash -c 'curl -sS https://get.symfony.com/cli/installer | bash' &> /dev/null
    mkdir -p "$HOME/.config"
    mv "$HOME/.symfony5" "$HOME/.config/symfony-cli"
    ln -sf "$HOME/.config/symfony-cli/bin/symfony" "$HOME/.local/bin/symfony"
fi

# Hyprland
rm -rf $HOME/.config/hypr
ln -s $DOTFILES/hyprland/hypr $HOME/.config/hypr

# Refresh config
source $HOME/.bashrc
